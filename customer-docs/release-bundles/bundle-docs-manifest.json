{
  "schema": "audittoolkit.bundle-docs-manifest.v1",
  "required": [
    {
      "source": "deployment/customer-deployment-pack.md",
      "destination": "CUSTOMER-DEPLOYMENT-PACK.md",
      "products": ["*"]
    },
    {
      "source": "deployment/release-bundle-structure.md",
      "destination": "RELEASE-BUNDLE-STRUCTURE.md",
      "products": ["*"]
    },
    {
      "source": "legal/eula.md",
      "destination": "legal/EULA.md",
      "products": ["*"]
    },
    {
      "source": "legal/liability-disclaimer-and-indemnity.md",
      "destination": "legal/LIABILITY-DISCLAIMER-AND-INDEMNITY.md",
      "products": ["*"]
    },
    {
      "source": "licensing/overview.md",
      "destination": "licensing/LICENSING.md",
      "products": ["*"]
    }
  ],
  "optional": [
    {
      "source": "releases/{product}/{version}/release-notes.md",
      "destination": "RELEASE-NOTES.md",
      "products": ["*"]
    }
  ],
  "excludedPatterns": ["**/INTERNAL-*", "**/*OPERATOR-RUNBOOK*", "**/*SIGNING*", "**/.github/**", "**/scripts/**", "**/docs-inventory.md"]
}
