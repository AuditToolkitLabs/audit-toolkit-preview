# Stripe webhook signing secret (required)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Keygen API credentials (required for license creation)
KEYGEN_ACCOUNT_ID=replace_me
KEYGEN_API_TOKEN=replace_me

# Optional override. Defaults to https://api.keygen.sh
KEYGEN_API_BASE_URL=https://api.keygen.sh

# Optional but recommended: allows fallback plan resolution from Stripe line items
# when checkout session metadata is missing or incomplete.
STRIPE_API_SECRET=sk_live_replace_me

# Required for Keygen webhook signature verification. Use your Keygen account public key PEM.
KEYGEN_WEBHOOK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace_me\n-----END PUBLIC KEY-----

# Required for direct customer/internal email delivery
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=licensing@audittoolkitlabs.com
RESEND_WEBHOOK_SECRET=whsec_replace_me

# Optional links included in outbound licensing and billing emails
PUBLIC_SITE_BASE_URL=https://audittoolkitlabs.com
LICENSE_TERMS_URL=https://audittoolkitlabs.com/licensing.html
SUPPORT_URL=https://audittoolkitlabs.com/support.html
PRIVACY_URL=https://audittoolkitlabs.com/privacy.html

# Optional Microsoft 365 Power Automate HTTP trigger for secondary internal automation
M365_FLOW_WEBHOOK_URL=

# Optional token for /admin/reissue-license endpoint
ADMIN_API_TOKEN=replace_with_long_random_value

# Optional NVD broker settings
# Keep NVD_API_KEY server-side only in the worker environment.
NVD_API_KEY=
NVD_BROKER_TOKEN=
NVD_ALLOW_NO_KEY=false
NVD_MIN_INTERVAL_MS=1200
NVD_NO_KEY_MIN_INTERVAL_MS=8000
NVD_CACHE_TTL_SECONDS=3600
NVD_QUOTA_WINDOW_SECONDS=86400
NVD_QUOTA_PER_WINDOW=5000
NVD_ANON_QUOTA_PER_WINDOW=250
NVD_ENFORCE_CUSTOMER_ID=false
NVD_PREWARM_MAX_CVE_IDS=100
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# Optional internal routing overrides
# Ops/incident notifications default to support@audittoolkitlabs.com
BILLING_OPS_EMAIL=
# Sales/commercial notifications default to license@audittoolkitlabs.com
BILLING_SALES_EMAIL=
# Optional escalation override (falls back to BILLING_OPS_EMAIL)
BILLING_ESCALATION_EMAIL=
