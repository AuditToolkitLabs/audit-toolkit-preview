# Cloudflare Worker Secrets Configuration
# Copy this file to .env.secrets and fill in actual values locally
# DO NOT commit .env.secrets to version control

# Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_API_SECRET=sk_live_your_stripe_api_key_here

# Keygen
KEYGEN_ACCOUNT_ID=your_keygen_account_id_here
KEYGEN_API_TOKEN=your_keygen_api_token_here
KEYGEN_WEBHOOK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nreplace_with_your_keygen_account_public_key\n-----END PUBLIC KEY-----

# Resend
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=licensing@audittoolkitlabs.com
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here

# Optional public/legal links included in outbound emails
PUBLIC_SITE_BASE_URL=https://audittoolkitlabs.com
LICENSE_TERMS_URL=https://audittoolkitlabs.com/licensing.html
SUPPORT_URL=https://audittoolkitlabs.com/support.html
PRIVACY_URL=https://audittoolkitlabs.com/privacy.html

# Microsoft 365 Power Automate
M365_FLOW_WEBHOOK_URL=https://default3918a5c9d91044038160c6dfb127f0.34.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/3fff1b79566f4ecea76ca3dabfaca72d/triggers/manual/paths/invoke?api-version=1

# Admin
ADMIN_API_TOKEN=your_admin_api_token_here

# NVD broker (keep key server-side only)
NVD_API_KEY=your_nvd_api_key_here
NVD_BROKER_TOKEN=optional_internal_broker_token
NVD_ALLOW_NO_KEY=false
NVD_MIN_INTERVAL_MS=1200
NVD_NO_KEY_MIN_INTERVAL_MS=8000
NVD_CACHE_TTL_SECONDS=3600
NVD_QUOTA_WINDOW_SECONDS=86400
NVD_QUOTA_PER_WINDOW=5000
NVD_ANON_QUOTA_PER_WINDOW=250
NVD_ENFORCE_CUSTOMER_ID=false
NVD_PREWARM_MAX_CVE_IDS=100
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
